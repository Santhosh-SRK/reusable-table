{
  "name": "task-tracker",
  "version": "1.0.0",
  "description": "Task tracking application with reusable data table library",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build reusable-table",
    "publish:lib": "npm run build:lib && cd dist/reusable-table && npm publish",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run task-tracker:storybook",
    "build-storybook": "ng run task-tracker:build-storybook"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/service-worker": "^18.2.14",
    "@tasktrack/reusable-table": "file:dist/reusable-table/tasktrack-reusable-table-1.0.0.tgz",
    "bootstrap": "^5.3.8",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.1802.0",
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular-devkit/core": "^18.2.0",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-onboarding": "^10.2.17",
    "@storybook/angular": "^10.2.17",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^18.2.1",
    "storybook": "^10.2.17",
    "typescript": "~5.5.2"
  }
}
